        top_features = [x[0] for x in top_outliers]
        
        fig, axes = plt.subplots(2, 5, figsize=(20, 10))
        axes = axes.flatten()
        
        for i, feature in enumerate(top_features):
            # 设置子图背景色为白色
            axes[i].set_facecolor('white')
            sns.kdeplot(self.features[feature], ax=axes[i], label='Original data', fill=True, alpha=0.7)
            sns.kdeplot(self.processed_data[feature], ax=axes[i], label='Processed data', fill=True, alpha=0.7)
            axes[i].set_title(f'{feature} Outlier Comparison', fontsize=16, fontweight='bold')
            axes[i].legend(fontsize=14, frameon=False)
            axes[i].tick_params(axis='both', labelsize=14, width=2)
            for label in axes[i].get_xticklabels():
                label.set_weight('bold')
                try:
                    label.set_text(f"{float(label.get_text()):.2f}")
                except:
                    pass
            for label in axes[i].get_yticklabels():
                label.set_weight('bold')
            axes[i].spines['top'].set_visible(True)
            axes[i].spines['right'].set_visible(True)
        
        # 设置整个图表背景色为白色
        fig.patch.set_facecolor('white')
        plt.tight_layout(pad=2.0)
        plot_path = os.path.join(self.output_dir, '异常值处理对比图.tif')
        plt.savefig(plot_path, dpi=600, format='tif', bbox_inches='tight', facecolor='white', edgecolor='none')
        plt.close()
        print(f"异常值处理对比图已保存至: {plot_path}")
    
    def standardize_data(self):
        print("正在进行标准化处理...")
        scaler = StandardScaler()
        standardized_data = scaler.fit_transform(self.processed_data)
        self.processed_data = pd.DataFrame(standardized_data, columns=self.processed_data.columns)
        self._plot_standardization_comparison(scaler)
        return self
    
