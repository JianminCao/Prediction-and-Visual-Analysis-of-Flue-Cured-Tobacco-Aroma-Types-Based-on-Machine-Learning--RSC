    def separation_analysis(self):
        """计算分离度（f01/f12/f02/f012），任意一指标f>0.8的特征进入后续流程"""
        print("正在进行特征分离度分析...")
        group0 = self.processed_data[self.flavor_types == 0]
        group1 = self.processed_data[self.flavor_types == 1]
        group2 = self.processed_data[self.flavor_types == 2]
        
        separation_list = []
        for feature in self.processed_data.columns:
            mean0, std0 = group0[feature].mean(), group0[feature].std()
            mean1, std1 = group1[feature].mean(), group1[feature].std()
            mean2, std2 = group2[feature].mean(), group2[feature].std()
            
            denominator01 = std0 + std1
            f01 = 1.18 * abs(mean0 - mean1) / denominator01 if denominator01 != 0 else np.inf
            denominator12 = std1 + std2
            f12 = 1.18 * abs(mean1 - mean2) / denominator12 if denominator12 != 0 else np.inf
            denominator02 = std0 + std2
            f02 = 1.18 * abs(mean0 - mean2) / denominator02 if denominator02 != 0 else np.inf
            
            valid_f = [f for f in [f01, f12, f02] if f != np.inf]
            f012 = np.mean(valid_f) if valid_f else np.inf
            
            def get_separation_ability(f_val):
                if f_val == np.inf:
                    return "无意义（分母为0）"
                elif f_val > 1.25:
                    return "几乎完全分离"
                elif f_val > 1.0:
                    return "分离能力良好"
                elif f_val > 0.8:
                    return "具有一定分离能力"
                else:
                    return "无有效分离能力"
            
            separation_list.append({
                '特征': feature,
                'f01（清甜-蜜甜）': round(f01, 4) if f01 != np.inf else "—",
                'f01分离能力': get_separation_ability(f01),
                'f12（蜜甜-醇甜）': round(f12, 4) if f12 != np.inf else "—",
                'f12分离能力': get_separation_ability(f12),
                'f02（清甜-醇甜）': round(f02, 4) if f02 != np.inf else "—",
                'f02分离能力': get_separation_ability(f02),
                'f012（综合分离度）': round(f012, 4) if f012 != np.inf else "—",
                'f012分离能力': get_separation_ability(f012)
            })
        
        self.separation_results = pd.DataFrame(separation_list).sort_values('f012（综合分离度）', ascending=False)
        separation_path = os.path.join(self.output_dir, '特征分离度结果.xlsx')
        self.separation_results.to_excel(separation_path, index=False)
        print(f"特征分离度结果已保存至: {separation_path}")
        
        # 筛选任意一f>0.8的特征
        valid_features_df = self.separation_results[
            (self.separation_results['f01（清甜-蜜甜）'] != "—") &
            (self.separation_results['f12（蜜甜-醇甜）'] != "—") &
            (self.separation_results['f02（清甜-醇甜）'] != "—")
        ].copy()
        valid_features_df['f01数值'] = valid_features_df['f01（清甜-蜜甜）'].astype(float)
        valid_features_df['f12数值'] = valid_features_df['f12（蜜甜-醇甜）'].astype(float)
        valid_features_df['f02数值'] = valid_features_df['f02（清甜-醇甜）'].astype(float)
        selected_features = valid_features_df[
            (valid_features_df['f01数值'] > 0.8) | 
            (valid_features_df['f12数值'] > 0.8) | 
            (valid_features_df['f02数值'] > 0.8)
        ]['特征'].tolist()
        
        self.processed_data = self.processed_data[selected_features]
        print(f"分离度筛选后保留 {len(selected_features)} 个特征（任意一指标f>0.8）")
        
        self._plot_separation_results()
        return self
    
    def _plot_separation_results(self):
        valid_sep = self.separation_results[self.separation_results['f012（综合分离度）'] != "—"].copy()
        valid_sep['f012数值'] = valid_sep['f012（综合分离度）'].astype(float)
        top15_sep = valid_sep.nlargest(15, 'f012数值')
        
