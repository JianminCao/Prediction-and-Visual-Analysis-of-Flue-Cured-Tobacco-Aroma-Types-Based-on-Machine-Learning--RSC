    def load_data(self):
        print("正在读取数据...")
        self.data = pd.read_excel(self.file_path)
        self.sample_labels = self.data.iloc[:, 0]
        self.flavor_types = self.data.iloc[:, 1]
        self.features = self.data.iloc[:, 2:]
        
        info_df = pd.DataFrame({
            '样品数量': [self.data.shape[0]],
            '特征数量': [self.features.shape[1]],
            '清甜型样品数': [(self.flavor_types == 0).sum()],
            '蜜甜型样品数': [(self.flavor_types == 1).sum()],
            '醇甜型样品数': [(self.flavor_types == 2).sum()]
        })
        info_path = os.path.join(self.output_dir, '数据基本信息.xlsx')
        info_df.to_excel(info_path, index=False)
        print(f"数据基本信息已保存至: {info_path}")
        return self
    
    def handle_outliers(self):
        print("正在处理异常值...")
        processed = self.features.copy()
        means = processed.mean()
        stds = processed.std()
        outlier_counts = {}
        
        for col in processed.columns:
            mean = means[col]
            std = stds[col]
            upper_limit = mean + 3 * std
            lower_limit = mean - 3 * std
            
            outliers = (processed[col] > upper_limit) | (processed[col] < lower_limit)
            outlier_counts[col] = outliers.sum()
            
            processed[col] = np.where(processed[col] > upper_limit, upper_limit, processed[col])
            processed[col] = np.where(processed[col] < lower_limit, lower_limit, processed[col])
        
        self.processed_data = processed
        self._plot_outlier_comparison(outlier_counts)
        
        outlier_df = pd.DataFrame(list(outlier_counts.items()), columns=['特征', '异常值数量'])
        outlier_path = os.path.join(self.output_dir, '异常值统计.xlsx')
        outlier_df.to_excel(outlier_path, index=False)
        print(f"异常值统计已保存至: {outlier_path}")
        return self
    
    def _plot_outlier_comparison(self, outlier_counts):
