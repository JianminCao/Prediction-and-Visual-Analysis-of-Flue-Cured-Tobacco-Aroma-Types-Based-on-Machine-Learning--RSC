    def correlation_analysis(self):
        """对随机森林筛选的特征进行相关性分析，删除相关性>0.8的低重要性特征"""
        print("正在进行特征相关性分析与冗余删除...")
        # 如果特征数量<=1，跳过相关性分析
        if len(self.top10_features) <= 1:
            print(f"特征数量仅为 {len(self.top10_features)}，无需进行相关性分析")
            self.correlation_matrix = None
            self.deleted_features = []
            delete_df = pd.DataFrame({'提示': ['特征数量不足，未删除任何特征']})
            delete_path = os.path.join(self.output_dir, '被删除的冗余特征列表.xlsx')
            delete_df.to_excel(delete_path, index=False)
            print(f"被删除的冗余特征列表已保存至: {delete_path}")
            print(f"相关性分析后，最终保留 {len(self.top10_features)} 个特征")
            return self
        
        # 1. 获取筛选特征的标准化数据
        top_features_data = self.processed_data[self.top10_features].copy()
        
        # 2. 计算Pearson相关系数矩阵（保留4位小数，图表显示两位）
        self.correlation_matrix = top_features_data.corr().round(4)
        
        # 3. 保存相关系数矩阵
        corr_path = os.path.join(self.output_dir, '特征相关系数矩阵.xlsx')
        self.correlation_matrix.to_excel(corr_path)
        print(f"特征相关系数矩阵已保存至: {corr_path}")
        
        # 4. 找出相关性>0.8的特征对（仅看上三角矩阵，避免重复）
        high_corr_pairs = []
        # 获取上三角矩阵的索引（行<列，避免(i,j)与(j,i)重复）
        for i in range(len(self.correlation_matrix.columns)):
            for j in range(i + 1, len(self.correlation_matrix.columns)):
                corr_value = self.correlation_matrix.iloc[i, j]
                if abs(corr_value) > 0.8:  # 绝对值>0.8视为高相关
                    feat1 = self.correlation_matrix.columns[i]
                    feat2 = self.correlation_matrix.columns[j]
                    high_corr_pairs.append({
                        '特征1': feat1,
                        '特征2': feat2,
                        '相关系数': round(corr_value, 2)  # 保留两位小数
                    })
        
        # 5. 处理高相关特征对：删除重要性更低的特征
        self.deleted_features = []
        if high_corr_pairs:
            # 构建特征-重要性字典，方便快速查询
            feat_importance = dict(zip(self.average_importance['特征'], self.average_importance['重要性']))
            
            for pair in high_corr_pairs:
                feat1 = pair['特征1']
                feat2 = pair['特征2']
                # 跳过已被标记删除的特征
                if feat1 in self.deleted_features or feat2 in self.deleted_features:
                    continue
                
                # 比较重要性，删除得分低的
                if feat_importance[feat1] > feat_importance[feat2]:
                    delete_feat = feat2
                else:
                    delete_feat = feat1
                
                self.deleted_features.append(delete_feat)
                # 从特征列表中移除
                self.top10_features.remove(delete_feat)
                print(f"高相关特征对（{feat1}-{feat2}，相关系数：{pair['相关系数']}）：删除{delete_feat}（重要性更低）")
        else:
            print("未发现相关性>0.8的特征对，无需删除冗余特征")
        
        # 6. 保存被删除的特征列表
        delete_df = pd.DataFrame({
            '被删除的冗余特征': self.deleted_features,
            '删除原因': ['与其他特征相关性>0.8且重要性更低'] * len(self.deleted_features)
        }) if self.deleted_features else pd.DataFrame({'提示': ['无冗余特征删除']})
        delete_path = os.path.join(self.output_dir, '被删除的冗余特征列表.xlsx')
        delete_df.to_excel(delete_path, index=False)
        print(f"被删除的冗余特征列表已保存至: {delete_path}")
        
        # 7. 绘制重构的相关性热力图
        self._plot_correlation_heatmap()
        
        # 8. 打印最终保留的特征数量
        print(f"相关性分析后，最终保留 {len(self.top10_features)} 个特征")
        return self
    
    def _plot_correlation_heatmap(self):
        """重构热力图：修复Ellipse导入 + 下三角椭圆+分级显著标记 + 移除对角线名称"""
        # 如果没有相关矩阵或特征数<=1，跳过绘图
        if self.correlation_matrix is None or len(self.correlation_matrix.columns) <= 1:
            print("特征数量不足，跳过相关性热力图绘制")
            return
        
        plt.figure(figsize=(12, 10))
        
        # 设置背景色为白色
        plt.gca().set_facecolor('white')
        plt.gcf().patch.set_facecolor('white')
        
        # 复制相关系数矩阵用于处理
        corr_mat = self.correlation_matrix.copy()
        
        # 1. 定义显著性标记（p值<0.05为*，<0.01为**）
        from scipy.stats import pearsonr
        p_matrix = np.zeros_like(corr_mat.values)
        for i in range(len(corr_mat.columns)):
            for j in range(len(corr_mat.columns)):
                if i != j:
                    corr, p = pearsonr(self.processed_data[corr_mat.columns[i]], 
                                      self.processed_data[corr_mat.columns[j]])
                    p_matrix[i, j] = p
        
        # 2. 创建上下三角掩码
        mask_upper = np.triu(np.ones_like(corr_mat, dtype=bool), k=1)  # 上三角（不含对角线）
        mask_lower = np.tril(np.ones_like(corr_mat, dtype=bool), k=-1)  # 下三角（不含对角线）
        
        # 3. 修复语法错误：合并mask参数，只传递一次
        # 绘制下三角：椭圆 + 分级显著标记
        sns.heatmap(corr_mat, 
                   mask=mask_upper,  # 只显示下三角（包括对角线）
                   cmap='RdBu_r',
                   center=0,
                   square=True,
                   linewidths=.5,
                   cbar=False,  # 先不显示颜色条
                   annot=False,
                   fmt='.2f')
        
        # 手动绘制下三角椭圆和分级显著标记
        ax = plt.gca()
        for i in range(len(corr_mat.columns)):
            for j in range(len(corr_mat.columns)):
                if i > j:  # 下三角
                    corr_val = corr_mat.iloc[i, j]
                    p_val = p_matrix[i, j]
                    
                    # 计算位置
                    x = j + 0.5
                    y = i + 0.5
                    
                    # 绘制椭圆（大小和颜色表示相关系数）
                    ellipse_size = abs(corr_val) * 0.8  # 椭圆大小
                    color = 'red' if corr_val > 0 else 'blue'
                    
                    # 根据p值设置透明度和显著标记
                    if p_val < 0.01:
                        alpha = 0.9
                        sig_mark = '**'
                    elif p_val < 0.05:
                        alpha = 0.7
                        sig_mark = '*'
                    else:
                        alpha = 0.4
                        sig_mark = ''
                    
                    # 关键修复：使用正确导入的Ellipse类
                    ellipse = Ellipse((x, y), ellipse_size, ellipse_size*0.6, 
                                     facecolor=color, alpha=alpha, edgecolor='black', linewidth=1)
                    ax.add_patch(ellipse)
                    
                    # 添加分级显著标记
                    if sig_mark:
                        plt.text(x, y, sig_mark, ha='center', va='center', 
                                fontsize=16, fontweight='bold', color='white')
        
        # 4. 绘制上三角：数值（保留两位小数）
        sns.heatmap(corr_mat,
                   mask=~mask_upper,  # 只显示上三角
                   cmap='RdBu_r',
                   center=0,
                   square=True,
                   linewidths=.5,
                   cbar=True,
                   cbar_kws={'shrink': .8, 'label': 'Correlation Coefficient'},
                   annot=True,
                   fmt='.2f',
                   annot_kws={'size': 16})  # 字号从17减小为16
        
        plt.title('Correlation Heatmap of Selected Features (Lower: Ellipse, Upper: Value)', 
                  fontsize=20, fontweight='bold')
        
        # 坐标轴设置：字号从19减小为18
        plt.xticks(fontsize=18)
        plt.yticks(fontsize=18)
        
        # 颜色条设置
        cbar = plt.gcf().axes[-1]
        cbar.set_ylabel('Correlation Coefficient', fontsize=18, fontweight='bold')
        cbar.tick_params(labelsize=16, width=2)
        for label in cbar.get_yticklabels():
            label.set_weight('bold')
        
        plt.tight_layout(pad=1.5)
        heatmap_path = os.path.join(self.output_dir, '特征相关性热力图.tif')
        plt.savefig(heatmap_path, dpi=600, format='tif', bbox_inches='tight', facecolor='white', edgecolor='none')
        plt.close()
        print(f"特征相关性热力图已保存至: {heatmap_path}")
    
