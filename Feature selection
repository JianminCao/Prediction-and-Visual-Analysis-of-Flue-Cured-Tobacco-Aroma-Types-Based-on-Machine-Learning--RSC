    # ---------------------- 核心修改：随机森林改为五折分层交叉验证，每折独立预处理 ----------------------
    def _process_fold_data(self, X_train_raw, X_test_raw):
        """
        对单折数据进行独立预处理：异常值处理 + 标准化
        返回处理后的训练/测试数据，以及预处理参数（异常值上下限、scaler）
        """
        # 1. 异常值处理（仅基于训练集计算上下限）
        train_processed = X_train_raw.copy()
        test_processed = X_test_raw.copy()
        
        # 计算训练集的均值和标准差
        train_means = train_processed.mean()
        train_stds = train_processed.std()
        
        # 存储每列的异常值上下限
        outlier_limits = {}
        
        for col in train_processed.columns:
            mean = train_means[col]
            std = train_stds[col]
            upper_limit = mean + 3 * std
            lower_limit = mean - 3 * std
            outlier_limits[col] = (lower_limit, upper_limit)
            
            # 处理训练集异常值
            train_processed[col] = np.where(train_processed[col] > upper_limit, upper_limit, train_processed[col])
            train_processed[col] = np.where(train_processed[col] < lower_limit, lower_limit, train_processed[col])
            
            # 用训练集的上下限处理测试集异常值
            test_processed[col] = np.where(test_processed[col] > upper_limit, upper_limit, test_processed[col])
            test_processed[col] = np.where(test_processed[col] < lower_limit, lower_limit, test_processed[col])
        
        # 2. 标准化（仅拟合训练集）
        scaler = StandardScaler()
        train_standardized = scaler.fit_transform(train_processed)
        test_standardized = scaler.transform(test_processed)
        
        # 转换为DataFrame
        X_train_processed = pd.DataFrame(train_standardized, columns=X_train_raw.columns, index=X_train_raw.index)
        X_test_processed = pd.DataFrame(test_standardized, columns=X_test_raw.columns, index=X_test_raw.index)
        
        return {
            'X_train_processed': X_train_processed,
            'X_test_processed': X_test_processed,
            'outlier_limits': outlier_limits,
            'scaler': scaler
        }
    
    def random_forest_selection(self):
        """
        修改为：使用五折分层交叉验证，每折独立预处理，计算平均特征重要性
        取消固定训练/测试集划分
        """
        print("正在进行随机森林重要性分析（五折分层交叉验证，每折独立预处理）...")
        
        # 准备原始特征数据（分离度筛选后的原始数据，未处理异常值和标准化）
        X_raw = self.features[self.processed_data.columns]  # 仅保留分离度筛选后的特征
        y = self.flavor_types
        sample_labels = self.sample_labels
        
        # 初始化五折分层交叉验证
        skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
        fold_importances = []  # 存储各折的特征重要性
        fold_scores = []       # 存储各折的测试集准确率
        self.fold_data = {}    # 存储各折的详细信息
        
        # 遍历每一折
        for fold_idx, (train_idx, test_idx) in enumerate(skf.split(X_raw, y), 1):
            print(f"\n处理第 {fold_idx} 折数据...")
            
            # 1. 划分该折的原始训练/测试数据
            X_train_raw = X_raw.iloc[train_idx]
            X_test_raw = X_raw.iloc[test_idx]
            y_train = y.iloc[train_idx]
            y_test = y.iloc[test_idx]
            sample_train = sample_labels.iloc[train_idx]
            sample_test = sample_labels.iloc[test_idx]
            
            # 2. 该折数据独立预处理（异常值处理 + 标准化）
            fold_processed = self._process_fold_data(X_train_raw, X_test_raw)
            X_train_processed = fold_processed['X_train_processed']
            X_test_processed = fold_processed['X_test_processed']
            
            # 3. 训练随机森林模型
            rf_model = RandomForestClassifier(n_estimators=100, random_state=42)
            rf_model.fit(X_train_processed, y_train)
            
            # 4. 评估该折性能
            fold_accuracy = rf_model.score(X_test_processed, y_test)
            fold_scores.append(fold_accuracy)
            
            # 5. 记录该折的特征重要性
            fold_importance = pd.DataFrame({
                '特征': X_raw.columns,
                '重要性': rf_model.feature_importances_,
                '折数': fold_idx
            })
            fold_importances.append(fold_importance)
            
            # 6. 存储该折的所有信息
            self.fold_data[f'fold_{fold_idx}'] = {
                'train_idx': train_idx,
                'test_idx': test_idx,
                'X_train_raw': X_train_raw,
                'X_test_raw': X_test_raw,
                'X_train_processed': X_train_processed,
                'X_test_processed': X_test_processed,
                'y_train': y_train,
                'y_test': y_test,
                'sample_train': sample_train,
                'sample_test': sample_test,
                'model': rf_model,
                'accuracy': fold_accuracy,
                'outlier_limits': fold_processed['outlier_limits'],
                'scaler': fold_processed['scaler']
            }
            
            print(f"第 {fold_idx} 折测试集准确率: {fold_accuracy:.4f}")
        
        # 7. 计算五折平均特征重要性
        all_importances = pd.concat(fold_importances, ignore_index=True)
        self.average_importance = all_importances.groupby('特征')['重要性'].mean().reset_index()
        self.average_importance = self.average_importance.sort_values('重要性', ascending=False)
        
        # 8. 计算交叉验证整体结果
        self.cv_scores = np.array(fold_scores)
        self.rf_importance = self.average_importance  # 平均重要性作为最终重要性
        
        # 9. 保存五折交叉验证信息
        cv_info_df = pd.DataFrame({
            '折数': [f'第{i}折' for i in range(1, 6)],
            '测试集准确率': [round(score, 4) for score in fold_scores],
            '训练集样品数': [len(self.fold_data[f'fold_{i}']['X_train_raw']) for i in range(1, 6)],
            '测试集样品数': [len(self.fold_data[f'fold_{i}']['X_test_raw']) for i in range(1, 6)]
        })
        # 添加汇总行
        summary_row = pd.DataFrame({
            '折数': ['平均值', '标准差', '最高分', '最低分'],
            '测试集准确率': [
                round(self.cv_scores.mean(), 4),
                round(self.cv_scores.std(), 4),
                round(self.cv_scores.max(), 4),
                round(self.cv_scores.min(), 4)
            ],
            '训练集样品数': ['—'] * 4,
            '测试集样品数': ['—'] * 4
        })
        cv_info_df = pd.concat([cv_info_df, summary_row], ignore_index=True)
        cv_info_path = os.path.join(self.output_dir, '五折交叉验证结果.xlsx')
        cv_info_df.to_excel(cv_info_path, index=False)
        print(f"\n五折交叉验证结果已保存至: {cv_info_path}")
        
        # 10. 处理特征重要性排名（兼容不足10个的情况）
        total_features = len(self.average_importance)
        select_n = min(10, total_features)
        top_n_importance = self.average_importance.head(select_n).copy()
        top_n_importance['排名'] = range(1, select_n + 1)
        top_n_importance = top_n_importance[['排名', '特征', '重要性']]
        
        # 保存重要性数据
        top_importance_path = os.path.join(self.output_dir, '随机森林重要性特征排名.xlsx')
        top_n_importance.to_excel(top_importance_path, index=False)
