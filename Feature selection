        self.deleted_features = None    # 新增：被删除的冗余特征列表
        self.rf_model = None  # 新增：存储随机森林模型
        self.rf_train_test_info = None  # 新增：存储训练测试集划分信息
        self.cv_scores = None  # 新增：存储五折交叉验证分数
        # 新增：保存训练测试集数据，避免作用域问题（改为存储各折数据）
        self.fold_data = {}  # 存储各折的训练/测试数据和预处理参数
