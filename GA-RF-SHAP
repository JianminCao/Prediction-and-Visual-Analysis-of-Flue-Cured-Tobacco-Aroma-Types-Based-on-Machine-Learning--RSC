# 替换文件名中的非法字符
def sanitize_filename(name):
    illegal_chars = ['/', '\\', ':', '*', '?', '"', '<', '>', '|']
    for char in illegal_chars:
        name = name.replace(char, '_')
    return name

# 3倍标准差盖帽法处理异常值
def cap_outliers_single(X_data, cap_limits=None):
    X_df = pd.DataFrame(X_data, columns=X_data.columns if hasattr(X_data, 'columns') else None)
    if cap_limits is None:
        cap_limits = {}
        for col in X_df.columns:
            mean = X_df[col].mean()
            std = X_df[col].std()
            upper_limit = mean + 3 * std
            lower_limit = mean - 3 * std
            cap_limits[col] = {'均值': mean, '标准差': std, '上限': upper_limit, '下限': lower_limit}
            X_df[col] = X_df[col].clip(lower=lower_limit, upper=upper_limit)
    else:
        for col in X_df.columns:
            if col in cap_limits:
                X_df[col] = X_df[col].clip(lower=cap_limits[col]['下限'], upper=cap_limits[col]['上限'])
    return X_df, cap_limits

# 遗传算法参数初始化函数（实整数编码）
def create_individual_creator(param_space):
    def init_individual():
        ind = []
        for param, (low, high) in param_space.items():
            if param in ['n_estimators', 'max_depth', 'min_samples_split', 
                         'min_samples_leaf', 'bootstrap']:
                ind.append(random.randint(low, high))
            elif param == 'max_features':
                ind.append(random.uniform(low, high))
        return creator.Individual(ind)
    return init_individual

# 自定义交叉函数：区分整数/浮点数
def custom_crossover(ind1, ind2):
    param_types = [0, 0, 0, 0, 1, 0]  # 0=整数，1=浮点数
    for i, (type_flag, gene1, gene2) in enumerate(zip(param_types, ind1, ind2)):
        if random.random() < 0.5:
            if type_flag == 0:
                ind1[i], ind2[i] = int((gene1 + gene2) / 2), int((gene1 + gene2) / 2)
            else:
                ind1[i], ind2[i] = (gene1 + gene2) / 2, (gene1 + gene2) / 2
    
    # 边界校验
    param_bounds = [
        (50, 200),    # n_estimators
        (3, 20),      # max_depth
        (2, 20),      # min_samples_split
        (1, 10),      # min_samples_leaf
        (0.1, 1.0),   # max_features
        (0, 1)        # bootstrap
    ]
    for i, (type_flag, val) in enumerate(zip(param_types, ind1)):
        low, high = param_bounds[i]
        if type_flag == 0:
            ind1[i] = int(max(low, min(high, val)))
        else:
            ind1[i] = max(low, min(high, val))
    for i, (type_flag, val) in enumerate(zip(param_types, ind2)):
        low, high = param_bounds[i]
        if type_flag == 0:
            ind2[i] = int(max(low, min(high, val)))
        else:
            ind2[i] = max(low, min(high, val))
    
    return ind1, ind2

# 自定义变异函数
def custom_mutation(ind, indpb):
    param_types = [0, 0, 0, 0, 1, 0]
    param_bounds = [
        (50, 200),    # n_estimators
        (3, 20),      # max_depth
        (2, 20),      # min_samples_split
        (1, 10),      # min_samples_leaf
        (0.1, 1.0),   # max_features
        (0, 1)        # bootstrap
    ]
    
    for i in range(len(ind)):
        if random.random() < indpb:
            type_flag = param_types[i]
            low, high = param_bounds[i]
            
            if type_flag == 0:
                mutation_step = random.randint(-5, 5)
                new_val = ind[i] + mutation_step
                ind[i] = int(max(low, min(high, new_val)))
            else:
                mutation_step = random.gauss(0, 0.1)
                new_val = ind[i] + mutation_step
                ind[i] = max(low, min(high, new_val))
    
    return ind,

# 遗传算法适应度函数
def evaluate_individual(individual, X_train, y_train, param_space):
    params = {}
    param_names = list(param_space.keys())
    for i, param in enumerate(param_names):
        val = individual[i]
        if param == 'n_estimators':
            params[param] = int(max(50, min(200, val)))
        elif param == 'max_depth':
            val_int = int(max(3, min(20, val)))
            params[param] = None if val_int == 20 else val_int
        elif param == 'min_samples_split':
            params[param] = int(max(2, min(20, val)))
        elif param == 'min_samples_leaf':
            params[param] = int(max(1, min(10, val)))
        elif param == 'max_features':
            params[param] = max(0.1, min(1.0, val))
        elif param == 'bootstrap':
            params[param] = bool(int(max(0, min(1, val))))
    
    rf = RandomForestClassifier(
        **params,
        random_state=42,
        class_weight='balanced',
        n_jobs=-1
    )
    
    try:
        scores = cross_val_score(rf, X_train, y_train, cv=5, scoring='f1_macro', error_score='raise')
        return (scores.mean(),)
    except Exception as e:
        print(f"参数评估失败：{params}，错误：{str(e)}")
        return (0.0,)

