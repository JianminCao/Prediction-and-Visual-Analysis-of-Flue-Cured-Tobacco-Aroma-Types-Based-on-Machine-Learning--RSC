    cm = confusion_matrix(y_test, y_test_pred)
    ax = sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                     xticklabels=[f'Predicted {cls}' for cls in [0, 1, 2]],
                     yticklabels=[f'Actual {cls}' for cls in [0, 1, 2]],
                     annot_kws={"weight": "bold"})
    plt.title('Random Forest Confusion Matrix (Test Set)', fontsize=14)
    plt.xlabel('Predicted Flavor Type', fontsize=12)
    plt.ylabel('Actual Flavor Type', fontsize=12)
    plt.tight_layout()
    plt.savefig(os.path.join(result_dir, '1_test_set_confusion_matrix.tif'), dpi=600, format='tif')
    plt.close()
    
    # -------------------------- SHAP解释（完整训练集） --------------------------
    print("\n=== Generating SHAP Explanations ===")
    try:
        # 使用完整训练集和最优参数
        explainer = shap.TreeExplainer(best_rf)
        shap_values = explainer.shap_values(X_train_scaled_df)
        n_classes = len(shap_values) if isinstance(shap_values, list) else 1
        
        # SHAP全局重要性图
