        return
    if not file_path.endswith(('.xlsx', '.xls')):
        print("Error: Please input Excel format files (.xlsx or .xls)!")
        return
    
    # 结果文件夹设置
    output_dir = os.path.dirname(file_path)
    if output_dir == "":
        output_dir = os.getcwd()
    result_dir = os.path.join(output_dir, "tobacco_rf_ga_optimization_results")
    os.makedirs(result_dir, exist_ok=True)
    print(f"\nResults will be saved to: {result_dir}")
    
    # 读取数据
    try:
        df = pd.read_excel(file_path, engine='openpyxl')
    except Exception as e1:
        try:
            df = pd.read_excel(file_path, engine='xlrd')
        except Exception as e2:
            print(f"Error reading file: {str(e2)}")
            return
    print(f"Successfully read data: {df.shape[0]} samples, {df.shape[1]} columns")
    
    # 数据划分
    if df.shape[1] < 3:
        print("Error: Insufficient columns! Need [Sample Label, Flavor Type, at least 1 feature]")
        return
    sample_labels = df.iloc[:, 0]
    y = df.iloc[:, 1]
    X = df.iloc[:, 2:]
    
    # 检查目标变量
    if not set(y.unique()).issubset({0, 1, 2}):
        print("Error: Flavor Type must only contain 0, 1, 2!")
        return
    
    # 8:2 划分训练集和测试集
    print("\n=== Splitting data into training (80%) and test (20%) sets ===")
    X_train_full, X_test, y_train_full, y_test, sample_labels_train, sample_labels_test = train_test_split(
        X, y, sample_labels, 
        test_size=0.2,
        random_state=42,
        stratify=y
    )
    
    # 保存训练集和测试集
    train_df = pd.DataFrame({
        'Sample_Label': sample_labels_train,
        'Flavor_Type': y_train_full
    }).join(X_train_full.reset_index(drop=True))
    train_df.to_excel(os.path.join(result_dir, 'train_set_80%.xlsx'), index=False)
    
    test_df = pd.DataFrame({
        'Sample_Label': sample_labels_test,
        'Flavor_Type': y_test
    }).join(X_test.reset_index(drop=True))
    test_df.to_excel(os.path.join(result_dir, 'test_set_20%.xlsx'), index=False)
    
    print(f"Training set: {X_train_full.shape[0]} samples")
    print(f"Test set: {X_test.shape[0]} samples (reserved for final evaluation)")
    
    # 训练集预处理（用于遗传算法优化）
    print("\n=== Preprocessing training set ===")
    # 1. 缺失值填充
    imputer = SimpleImputer(strategy='median')
    X_train_imputed = imputer.fit_transform(X_train_full)
    X_train_imputed_df = pd.DataFrame(X_train_imputed, columns=X.columns, index=sample_labels_train)
    
    # 2. 异常值处理
    X_train_capped, cap_limits = cap_outliers_single(X_train_imputed_df)
    
    # 3. 标准化
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train_capped)
    X_train_scaled_df = pd.DataFrame(X_train_scaled, columns=X.columns, index=sample_labels_train)
    
    # 保存预处理记录
    cap_report = pd.DataFrame.from_dict(cap_limits, orient='index')[['均值', '标准差', '下限', '上限']]
    cap_report.to_excel(os.path.join(result_dir, '0_outlier_capping_records.xlsx'))
    missing_report = pd.DataFrame({'Feature': X.columns, 'Imputation_Median': imputer.statistics_})
    missing_report.to_excel(os.path.join(result_dir, '0_missing_value_records.xlsx'), index=False)
    
    # -------------------------- 遗传算法优化随机森林 --------------------------
    # 定义参数空间
    param_space = {
        'n_estimators': (50, 200),      # 整数
        'max_depth': (3, 20),           # 整数
        'min_samples_split': (2, 20),   # 整数
        'min_samples_leaf': (1, 10),    # 整数
        'max_features': (0.1, 1.0),     # 浮点数
        'bootstrap': (0, 1)             # 整数（0=False/1=True）
    }
    
    # 初始化DEAP
    if 'FitnessMax' in dir(creator):
        del creator.FitnessMax
    if 'Individual' in dir(creator):
        del creator.Individual
    
    creator.create("FitnessMax", base.Fitness, weights=(1.0,))
    creator.create("Individual", list, fitness=creator.FitnessMax)
    
    toolbox = base.Toolbox()
    individual_creator = create_individual_creator(param_space)
    toolbox.register("individual", individual_creator)
    toolbox.register("population", tools.initRepeat, list, toolbox.individual)
    
    # 注册遗传算子
    toolbox.register("evaluate", evaluate_individual, X_train=X_train_scaled, y_train=y_train_full, param_space=param_space)
    toolbox.register("mate", custom_crossover)
    toolbox.register("mutate", custom_mutation, indpb=0.2)
    toolbox.register("select", tools.selTournament, tournsize=3)
    
    # 遗传算法参数
    POPULATION_SIZE = 100    # 初始种群
    MAX_GENERATIONS = 50     # 最大迭代次数
    CXPB = 0.7
    MUTPB = 0.2
    
    # 运行遗传算法
    print("\n=== Starting Genetic Algorithm Optimization ===")
    print(f"Population size: {POPULATION_SIZE}, Max generations: {MAX_GENERATIONS}")
    random.seed(42)
    pop = toolbox.population(n=POPULATION_SIZE)
    hof = tools.HallOfFame(1)
    stats = tools.Statistics(lambda ind: ind.fitness.values)
    stats.register("avg", np.mean)
    stats.register("std", np.std)
    stats.register("min", np.min)
    stats.register("max", np.max)
    
    pop, log = algorithms.eaSimple(
        pop, toolbox,
        cxpb=CXPB, mutpb=MUTPB,
        ngen=MAX_GENERATIONS,
        stats=stats, halloffame=hof,
        verbose=True
    )
    
    # 解码最优参数
    best_ind = hof[0]
    best_params = {}
    param_names = list(param_space.keys())
    for i, param in enumerate(param_names):
        val = best_ind[i]
        if param == 'n_estimators':
            best_params[param] = int(val)
        elif param == 'max_depth':
            val_int = int(val)
            best_params[param] = None if val_int == 20 else val_int
        elif param == 'min_samples_split':
            best_params[param] = int(val)
        elif param == 'min_samples_leaf':
            best_params[param] = int(val)
        elif param == 'max_features':
            best_params[param] = float(val)
        elif param == 'bootstrap':
            best_params[param] = bool(int(val))
    
    # 保存最优参数
    print("\n=== Best Parameters from GA ===")
    for k, v in best_params.items():
        print(f"{k}: {v} (type: {type(v).__name__})")
    best_params_df = pd.DataFrame([best_params])
    best_params_df.to_excel(os.path.join(result_dir, '0_best_ga_parameters.xlsx'), index=False)
    
    # 保存迭代日志
    log_df = pd.DataFrame(log)
    log_df.to_excel(os.path.join(result_dir, '0_ga_iteration_log.xlsx'), index=False)
    
    # -------------------------- 测试集评估 --------------------------
    print("\n=== Evaluating Best Model on Test Set ===")
    # 预处理测试集
    X_test_imputed = imputer.transform(X_test)
    X_test_imputed_df = pd.DataFrame(X_test_imputed, columns=X.columns, index=sample_labels_test)
    X_test_capped, _ = cap_outliers_single(X_test_imputed_df, cap_limits)
    X_test_scaled = scaler.transform(X_test_capped)
    X_test_scaled_df = pd.DataFrame(X_test_scaled, columns=X.columns, index=sample_labels_test)
    
    # 训练最优模型
    best_rf = RandomForestClassifier(
        **best_params,
        random_state=42,
        class_weight='balanced',
        n_jobs=-1
    )
    best_rf.fit(X_train_scaled, y_train_full)
    
    # 测试集预测
    y_test_pred = best_rf.predict(X_test_scaled)
    y_test_proba = best_rf.predict_proba(X_test_scaled)
    
    # 计算测试集指标
    test_acc = accuracy_score(y_test, y_test_pred)
    test_precision = precision_score(y_test, y_test_pred, average='macro', zero_division=0)
    test_recall = recall_score(y_test, y_test_pred, average='macro', zero_division=0)
    test_f1 = f1_score(y_test, y_test_pred, average='macro', zero_division=0)
    
    try:
        test_auc = roc_auc_score(y_test, y_test_proba, average='macro', multi_class='ovr')
    except Exception as e:
        test_auc = None
        print(f"Warning: AUC calculation failed: {str(e)}")
    
    # 保存测试集评估结果
    test_results = {
        'Accuracy': f"{test_acc:.3f}",
        'Precision': f"{test_precision:.3f}",
        'Recall': f"{test_recall:.3f}",
        'F1-Score': f"{test_f1:.3f}",
        'AUC': f"{test_auc:.3f}" if test_auc else "N/A"
    }
    test_results_df = pd.DataFrame([test_results])
    test_results_df.to_excel(os.path.join(result_dir, '1_test_set_evaluation.xlsx'), index=False)
    
