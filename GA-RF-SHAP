        ax.set_xlabel('Mean Absolute SHAP Value', fontsize=12, fontweight='bold')
        ax.set_ylabel('Features', fontsize=12, fontweight='bold')
        plt.tight_layout()
        plt.savefig(os.path.join(result_dir, '2_shap_global_importance.tif'), dpi=600, format='tif')
        plt.close()
        
        # SHAP蜜蜂图（按类别）
