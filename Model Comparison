        plt.ylim(0, 1.0)
        plt.legend(loc='lower center', bbox_to_anchor=(0.5, -0.15), ncol=5, fontsize=10)
        plt.tight_layout()
        plt.savefig(os.path.join(result_dir, '5_model_performance_comparison_training_set.tif'), dpi=600, format='tif')
